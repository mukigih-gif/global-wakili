{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@global-wakili/database": ["packages/database/src"],
      "@global-wakili/database/*": ["packages/database/src/*"],
      "@global-wakili/core/*": ["packages/core/*"],
      "@global-wakili/common/*": ["packages/common/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "noEmit": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "_archive",
    "**/_archive/**",
    "**/*.bak.ts",
    "**/*.backup.ts",
    "**/*.old.ts"
  ]
}