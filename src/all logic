model Matter {
  id            String   @id @default(uuid())
  reference     String   @unique // The GW-2026-001 we built
  title         String
  status        String   @default("OPEN")
  
  // NEW FEATURES
  assignedTo    String?  // Link to a Staff member
  progressNote  String?  // The latest update on the case
  courtDate     DateTime? // For the Calendar Module
  
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  // ... rest of your fields
}