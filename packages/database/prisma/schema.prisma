  id       String @id @default(cuid())
  tenantId String
  runId    String

  bankTransactionId   String?
  trustTransactionId  String?
  clientTrustLedgerId String?

  matchType      String
  matchedAmount  Decimal @db.Decimal(18, 2)
  varianceAmount Decimal @default(0) @db.Decimal(18, 2)

  varianceExplanation String?
