  varianceApprovedBy  String?
  varianceApprovedAt  DateTime?

  status ReconciliationStatus @default(PENDING)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  run               ReconciliationRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  bankTransaction   BankTransaction?   @relation(fields: [bankTransactionId], references: [id])
  trustTransaction  TrustTransaction?  @relation(fields: [trustTransactionId], references: [id])
  clientTrustLedger ClientTrustLedger? @relation(fields: [clientTrustLedgerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([runId])
  @@index([bankTransactionId])
  @@index([trustTransactionId])
  @@index([clientTrustLedgerId])
  @@index([varianceStatus])
