  branch                Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  accountName           String
  accountNumber         String              @unique
  bankName              String
  routingNumber         String?
  swiftCode             String?
  currentBalance        Decimal             @db.Decimal(14, 2)
  lastReconciled        DateTime?
  reconciliationBalance Decimal             @db.Decimal(14, 2)
  isActive              Boolean             @default(true)
  transactions          OfficeTransaction[]
  reconciliations       OfficeReconciliation[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @default(now()) @updatedAt

  @@index([tenantId])
}

model TrustTransaction {
  id               String             @id @default(cuid())
  trustAccountId   String
  account          TrustAccount       @relation(fields: [trustAccountId], references: [id], onDelete: Cascade)
  matterId         String?
  matter           Matter?            @relation(fields: [matterId], references: [id], onDelete: SetNull)
  reference        String
  description      String
  transactionType  String
  amount           Decimal            @db.Decimal(12, 2)
  debit            Decimal            @default(0) @db.Decimal(12, 2)
  credit           Decimal            @default(0) @db.Decimal(12, 2)
  transactionDate  DateTime
  postedDate       DateTime?
  isReconciled     Boolean            @default(false)
  reconciliationId String?
  reconciliation   TrustReconciliation? @relation(fields: [reconciliationId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @default(now()) @updatedAt

  @@index([trustAccountId])
  @@index([matterId])
  @@index([transactionDate])
}

model TrustReconciliation {
  id               String           @id @default(cuid())
  trustAccountId   String
  account          TrustAccount     @relation(fields: [trustAccountId], references: [id], onDelete: Cascade)
  statementDate    DateTime
  statementBalance Decimal          @db.Decimal(12, 2)
  transactions     TrustTransaction[]
  isCompleted      Boolean          @default(false)
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @default(now()) @updatedAt

  @@index([trustAccountId])
}

model OfficeReconciliation {
  id              String        @id @default(cuid())
  officeAccountId String
  account         OfficeAccount @relation(fields: [officeAccountId], references: [id], onDelete: Cascade)
  statementDate   DateTime
  statementBalance Decimal      @db.Decimal(14, 2)
  transactions    OfficeTransaction[]
  isCompleted     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt

  @@index([officeAccountId])
}

model ExpenseReconciliation {
  id           String       @id @default(cuid())
  expenseId    String       @unique
  expense      ExpenseEntry @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  reconciledBy String
  reconciledAt DateTime     @default(now())
  status       String
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @default(now()) @updatedAt
}

// --- RECEPTION & SAAS ACTIVITY LOGS (added) ---
model SaasActivityLog {
  id          String    @id @default(cuid())
  tenantId    String
  action      String    // e.g., "SUSPEND_ACCESS", "GRANT_EXTENSION"
  performedBy String    // SuperAdmin ID
  timestamp   DateTime  @default(now())
  reason      String?

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([timestamp])
}

model ReceptionLog {
  id              String    @id @default(cuid())
  tenantId        String
  type            LogType

  // common fields
  subject         String    // Name of visitor, caller, or document title
  description     String?
  timestamp       DateTime  @default(now())
  receivedById    String    // the receptionist/user on duty

  // Document specifics
  matterId        String?
  isUrgent        Boolean   @default(false)
  deliveryMethod  String?   // e.g., "Hand Delivered", "Courier", "Post"
  trackingNumber  String?
  digitalCopyUrl  String?   // S3 Link for the stamped/scanned document

  // Visitor/Call specifics
  personMeeting   String?   // Advocate the visitor is seeing
  durationMinutes Int?
  isPlanned       Boolean   @default(true)

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter          Matter?   @relation(fields: [matterId], references: [id], onDelete: SetNull)
  receivedBy      User      @relation("ReceptionReceivedBy", fields: [receivedById], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([matterId])
  @@index([receivedById])
  @@index([timestamp])
}