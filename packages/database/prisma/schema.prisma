  @@index([matterId])
  @@index([userId])
  @@index([status])
}

// --- UNBILLED WIP, INVOICES, BILLING RUNS ---
model UnbilledWip {
  id                  String   @id @default(cuid())
  matterId            String   @unique
  matter              Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  timeEntryCount      Int
  totalHours          Float
  totalUnbilledAmount Decimal  @db.Decimal(12, 2)
  lastUpdatedAt       DateTime @default(now())
}

model Invoice {
  id                 String       @id @default(cuid())
  invoiceNumber      String       @unique
  tenantId           String
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kraControlNumber   String?      @unique
  etimsReference     String?      @unique
  etimsValidated     Boolean      @default(false)
  etimsValidatedAt   DateTime?
  total              Decimal      @db.Decimal(12, 2)
  taxAmount          Decimal      @default(0) @db.Decimal(12, 2)
  netAmount          Decimal      @db.Decimal(12, 2)
  status             InvoiceStatus @default(DRAFT)
  matterId           String
  matter             Matter       @relation(fields: [matterId], references: [id], onDelete: Cascade)
  branchId           String?
  branch             Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  reconciledAt       DateTime?
