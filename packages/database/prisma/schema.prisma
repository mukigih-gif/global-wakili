  billingRun         BillingRun?  @relation(fields: [billingRunId], references: [id], onDelete: SetNull)
  issuedDate         DateTime     @default(now())
  dueDate            DateTime?
  paidDate           DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @default(now()) @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([matterId])
  @@index([etimsValidated])
  @@index([issuedDate])
}

model BillingRun {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runDate           DateTime
  period            String
  invoicesGenerated Int
  totalAmount       Decimal   @db.Decimal(14, 2)
  status            String
  submittedToEtims  Boolean   @default(false)
  createdBy         String
  invoices          Invoice[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  @@index([tenantId])
  @@index([period])
}

// --- ACCOUNTING: CHART, BALANCES, JOURNALS, LEDGER LINES, PAYROLL ---
model ChartOfAccount {
  id         String         @id
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  type       String
  description String?
  lines      LedgerLine[]
  balances   AccountBalance[]

  @@unique([tenantId, id])
  @@index([tenantId])
}

model AccountBalance {
  id           String         @id @default(cuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountId    String
  account      ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  debitBalance Decimal        @db.Decimal(14, 2)
  creditBalance Decimal       @db.Decimal(14, 2)
  asOfDate     DateTime
  lastUpdatedAt DateTime      @default(now())

  @@unique([tenantId, accountId, asOfDate])
  @@index([tenantId, asOfDate])
}

model JournalEntry {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reference   String
  description String
  date        DateTime     @default(now())
  matterId    String?
  matter      Matter?      @relation(fields: [matterId], references: [id], onDelete: SetNull)
  isReconciled Boolean     @default(false)
  lines       LedgerLine[]
  createdAt   DateTime     @default(now())

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([date])
}

model LedgerLine {
  id        String         @id @default(cuid())
  journalId String
  journal   JournalEntry   @relation(fields: [journalId], references: [id], onDelete: Cascade)
  accountId String
  account   ChartOfAccount @relation(fields: [accountId], references: [id])
  debit     Decimal        @db.Decimal(12, 2)
  credit    Decimal        @db.Decimal(12, 2)

  @@index([journalId])
  @@index([accountId])
}

model PayrollRecord {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month           Int
  year            Int
  basicSalary     Decimal  @db.Decimal(12, 2)
  allowances      Decimal  @default(0) @db.Decimal(12, 2)
  bonus           Decimal  @default(0) @db.Decimal(12, 2)
  grossSalary     Decimal  @db.Decimal(12, 2)
  paye            Decimal  @default(0) @db.Decimal(12, 2)
  housingLevy     Decimal  @default(0) @db.Decimal(12, 2)
  shif            Decimal  @default(0) @db.Decimal(12, 2)
  nssf            Decimal  @default(0) @db.Decimal(12, 2)
  nhif            Decimal  @default(0) @db.Decimal(12, 2)
  otherDeductions Decimal  @default(0) @db.Decimal(12, 2)
  netSalary       Decimal  @db.Decimal(12, 2)
  paymentMethod   String?
  paidDate        DateTime?
  transactionRef  String?
  processedBy     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@unique([tenantId, userId, month, year])
  @@index([tenantId])
  @@index([userId])
}

// --- NOTIFICATIONS, DOCUMENTS, CLIENTS, TRUST LEDGER, SUPPLIERS ---
model Notification {
  id            String              @id @default(cuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel       NotificationChannel
  systemTitle   String?
  systemMessage String?
  emailSubject  String?
  emailBody     String?
  smsContent    String?
  status        NotificationStatus  @default(PENDING)
  sentAt        DateTime?
  deliveredAt   DateTime?
  failedAt      DateTime?
  attemptCount  Int                 @default(0)
  nextRetryAt   DateTime?
  readAt        DateTime?
  clickedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @default(now()) @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

model Document {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matterId    String?
  matter      Matter?  @relation(fields: [matterId], references: [id], onDelete: SetNull)
  title       String
  description String?
  fileUrl     String
  fileSize    Int
  mimeType    String
  fileHash    String
  version     Int      @default(1)
  previousId  String?
  uploadedBy  String
  uploader    User     @relation("UploadedBy", fields: [uploadedBy], references: [id])
  expiryDate  DateTime?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  deletedAt   DateTime?

  @@index([tenantId])
  @@index([matterId])
}

model Client {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  email      String
  phone      String
  kraPin     String?  @unique
  idNumber   String?
  kycStatus  String   @default("PENDING")
  matters    Matter[]
  trustLedger ClientTrustLedger[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

