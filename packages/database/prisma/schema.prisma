generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                           String                        @id @default(cuid())
  deletedAt                    DateTime?
  suspendedAt                  DateTime?
  archivedAt                   DateTime?
  deletionRequestedAt          DateTime?
  deletionApprovedAt           DateTime?
  deletionApprovedBy           String?
  name                         String                        @unique
  slug                         String                        @unique
  description                  String?
  kraPin                       String                        @unique
  etimsId                      String?                       @unique
  subscriptionPlan             PlanType                      @default(BASIC)
  subscriptionStatus           SubscriptionStatus            @default(ACTIVE)
  billingCycleStart            DateTime
  billingCycleEnd              DateTime
  logoUrl                      String?
  faviconUrl                   String?
  primaryColor                 String                        @default("#1A1A1A")
  accentColor                  String                        @default("#D4AF37")
  fontFamily                   String                        @default("Inter")
  currency                     String                        @default("KES")
  timezone                     String                        @default("Africa/Nairobi")
  locale                       String                        @default("en-KE")
  dateFormat                   String                        @default("DD/MM/YYYY")
  dataResidencyRegion          String                        @default("KE")
  complianceMode               Boolean                       @default(true)
  enableEtims                  Boolean                       @default(true)
  enableTrust                  Boolean                       @default(true)
  enableAml                    Boolean                       @default(true)
  gdprMode                     Boolean                       @default(false)
  auditLogRetention            Int                           @default(2555)
  backupRetention              Int                           @default(90)
  betaFeatures                 String[]                      @default([])
  disabledFeatures             String[]                      @default([])
  accountingMethod             AccountingMethod              @default(ACCRUAL)
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  lastLoginAt                  DateTime?
  mPesaVolumeMonth             Decimal                       @default(0) @db.Decimal(18, 2)
  storageUsedGb                Decimal                       @default(0) @db.Decimal(10, 2)
  totalMatters                 Int                           @default(0)
  totalUsers                   Int                           @default(0)
  accountBalances              AccountBalance[]
  apiKeys                      ApiKey[]
  approvals                    Approval[]
  auditAlerts                  AuditAlert[]
  auditLogs                    AuditLog[]
  billingRuns                  BillingRun[]
  branches                     Branch[]
  chartOfAccounts              ChartOfAccount[]
  clients                      Client[]
  consentRecords               ConsentRecord[]
  disputes                     Dispute[]
  documents                    Document[]
  evidenceItems                EvidenceItem[]
  expressServices              ExpressService[]
  featureFlags                 FeatureFlag[]
  fieldEncryptions             FieldEncryption[]
  invoices                     Invoice[]
  invoiceSequences             InvoiceSequence[]
  paymentReceipts              PaymentReceipt[]
  creditNotes                  CreditNote[]
  complianceReports            ComplianceReport[]
  externalJobQueues            ExternalJobQueue[]
  journalEntries               JournalEntry[]
  journalLines                 JournalLine[]
  matterTemplates              MatterTemplate[]
  notifications                Notification[]
  officeAccounts               OfficeAccount[]
  payrollRecords               PayrollRecord[]
  permissions                  Permission[]
  rateLimitLogs                RateLimitLog[]
  receptionLogs                ReceptionLog[]
  roles                        Role[]
  platformActivityLogs PlatformActivityLog[]
  suppliers                    Supplier[]
  encryptionKeys               TenantEncryptionKey[]
  trustAccounts                TrustAccount[]
  users                        User[]
  webhooks                     Webhook[]
  workflows                    Workflow[]
  workspaces                   Workspace[]
  accountingPeriods            AccountingPeriod[]
  exchangeRates                ExchangeRate[]
  bankStatements               BankStatement[]
  bankTransactions             BankTransaction[]
  reconciliationRuns           ReconciliationRun[]
  reconciliationMatches        ReconciliationMatch[]
  trustReconciliations         TrustReconciliation[]
  officeReconciliations        OfficeReconciliation[]
  expenseReconciliations       ExpenseReconciliation[]
  contracts                    Contract[]
  contractVersions             ContractVersion[]
  clientContacts               ClientContact[]
  clientKycProfiles            ClientKycProfile[]
  matters                      Matter[]
  timeEntries                  TimeEntry[]
  disbursements                Disbursement[]
  officeTransactions           OfficeTransaction[]
  expenseEntries               ExpenseEntry[]
  unbilledWips                 UnbilledWip[]
  clientTrustLedgers           ClientTrustLedger[]
  calendarEvents               CalendarEvent[]
  matterTasks                  MatterTask[]
  taskComments                 TaskComment[]
  attendances                  Attendance[]
  leaveRequests                LeaveRequest[]
  employeePerformances         EmployeePerformance[]
  employeeGoals                EmployeeGoal[]
  employeeDocuments            EmployeeDocument[]
  commissionPayouts            CommissionPayout[]
  trustTransactions            TrustTransaction[]
  invoiceLines                 InvoiceLine[]
  paymentReceiptAllocations    PaymentReceiptAllocation[]
  vendorBills                  VendorBill[]
  vendorBillLines              VendorBillLine[]
  vendorPayments               VendorPayment[]
  requestForQuotations         RequestForQuotation[]
  requestForQuotationItems     RequestForQuotationItem[]
  requestForQuotationSuppliers RequestForQuotationSupplier[]
  quotations                   Quotation[]
  quotationLines               QuotationLine[]
  purchaseOrders               PurchaseOrder[]
  purchaseOrderLines           PurchaseOrderLine[]
  recurringExpenseTemplates    RecurringExpenseTemplate[]
  payrollBatches               PayrollBatch[]
  payslips                     Payslip[]
  timerSessions                TimerSession[]
  departments                  Department[]
  jobTitles                    JobTitle[]
  employeeProfiles             EmployeeProfile[]
  statutoryDeductionRecords    StatutoryDeductionRecord[]
  calendarReminders            CalendarReminder[]
  calendarRecurrenceRules      CalendarRecurrenceRule[]
  calendarSubscriptions        CalendarSubscription[]
  externalCalendarAccounts     ExternalCalendarAccount[]
  calendarSyncCursors          CalendarSyncCursor[]
  tenantMemberships            TenantMembership[]
  rateCards                    RateCard[]
  writeOffs                    WriteOff[]
  courtHearings                CourtHearing[]
  profitabilitySnapshots       MatterProfitabilitySnapshot[]
  complianceChecks             ClientComplianceCheck[]
  purchaseOrderReceipts        PurchaseOrderReceipt[]
  disbursementNotes            DisbursementRequestNote[]
  leaveBalances                LeaveBalance[]
  purchaseOrderReceiptLines    PurchaseOrderReceiptLine[]
  withholdingTaxCertificates   WithholdingTaxCertificate[]
  paymentRefunds               PaymentRefund[]
  analyticsMetrics              AnalyticsMetric[]
  analyticsSnapshots            AnalyticsSnapshot[]
  analyticsInsights             AnalyticsInsight[]

  @@index([subscriptionStatus])
  @@index([createdAt])
  @@index([dataResidencyRegion])
}

model TenantMembership {
  id       String  @id @default(cuid())
  tenantId String
  userId   String
  roleId   String?

  isOwner Boolean @default(false)
  status  String  @default("ACTIVE")

  invitedBy  String?
  invitedAt  DateTime?
  acceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role?  @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([status])
}

model Workspace {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  brand       String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Branch {
  id                        String                     @id @default(cuid())
  tenantId                  String
  name                      String
  kraPin                    String                     @unique
  etimsId                   String?                    @unique
  location                  String?
  phone                     String?
  email                     String?
  etimsDrn                  String?                    @unique
  vscuSerial                String?                    @unique
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices                  Invoice[]
  matters                   Matter[]
  clients                   Client[]
  timeEntries               TimeEntry[]
  officeAccounts            OfficeAccount[]
  trustAccounts             TrustAccount[]
  users                     User[]
  journalLines              JournalLine[]
  vendorBills               VendorBill[]
  purchaseOrders            PurchaseOrder[]
  requestForQuotations      RequestForQuotation[]
  expenseEntries            ExpenseEntry[]
  recurringExpenseTemplates RecurringExpenseTemplate[]
  departments               Department[]
  employeeProfiles          EmployeeProfile[]
  attendances               Attendance[]
  payrollBatches            PayrollBatch[]

  @@unique([tenantId, kraPin])
  @@index([tenantId])
}

model Device {
  id                 String            @id @default(cuid())
  userId             String
  deviceFingerprint  String            @unique
  deviceName         String
  deviceType         String
  osName             String?
  osVersion          String?
  browserName        String?
  browserVersion     String?
  trustStatus        DeviceTrustStatus @default(UNTRUSTED)
  trustedAt          DateTime?
  trustedBy          String?
  lastUsedAt         DateTime          @default(now())
  ipAddressHistory   String[]          @default([])
  locationHistory    String[]          @default([])
  lastIpAddress      String?
  lastLocation       String?
  riskScore          Int               @default(0)
  suspiciousActivity Boolean           @default(false)
  flags              String[]          @default([])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt
  auditLogs          AuditLog[]
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions           Session[]

  @@index([userId])
  @@index([trustStatus])
  @@index([lastUsedAt])
}

model Session {
  id                  String        @id @default(cuid())
  userId              String
  deviceId            String?
  tenantId            String?
  sessionToken        String        @unique
  refreshToken        String?       @unique
  tokenVersion        Int           @default(1)
  status              SessionStatus @default(ACTIVE)
  issuedAt            DateTime      @default(now())
  expiresAt           DateTime
  lastActivityAt      DateTime      @default(now())
  lastActivityType    String?
  ipAddress           String
  userAgent           String
  location            String?
  mfaVerified         Boolean       @default(false)
  mfaMethod           MfaMethod?
  mfaVerifiedAt       DateTime?
  riskLevel           String        @default("LOW")
  requiresMfaReverify Boolean       @default(false)
  suspiciousActivity  Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @default(now()) @updatedAt
  device              Device?       @relation(fields: [deviceId], references: [id])
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, expiresAt])
  @@index([deviceId])
  @@index([lastActivityAt])
}

model MfaSecret {
  id              String    @id @default(cuid())
  userId          String    @unique
  totpSecret      String?
  totpVerified    Boolean   @default(false)
  backupCodes     String?
  backupCodesUsed String[]  @default([])
  otpToken        String?
  otpExpiresAt    DateTime?
  otpAttempts     Int       @default(0)
  otpMaxAttempts  Int       @default(3)
  recoveryEmail   String?
  recoveryPhone   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                                  String                        @id @default(cuid())
  email                               String
  name                                String
  accountNumber                       String?
  admissionNumber                     String?                       @unique
  employeeProfile                     EmployeeProfile?
  bankName                            String?
  basicSalary                         Decimal                       @default(0) @db.Decimal(18, 2)
  branchId                            String?
  createdAt                           DateTime                      @default(now())
  defaultRate                         Decimal                       @default(0) @db.Decimal(18, 2)
  deletedAt                           DateTime?
  department                          String?
  emailNotifications                  Boolean                       @default(true)
  failedLoginAttempts                 Int                           @default(0)
  googleId                            String?                       @unique
  idNumber                            String?                       @unique
  taxableAllowances                   Decimal                       @default(0) @db.Decimal(12, 2)
  nonTaxableAllowances                Decimal                       @default(0) @db.Decimal(12, 2)
  isLocked                            Boolean                       @default(false)
  kraPin                              String?                       @unique
  language                            String                        @default("en-KE")
  lastActivityAt                      DateTime                      @default(now())
  lastLoginAt                         DateTime?
  lockReason                          String?
  lockedUntil                         DateTime?
  shifNumber                          String?                       @unique
  nssfNumber                          String?
  oauth2Providers                     String[]                      @default([])
  passwordChangedAt                   DateTime?
  passwordExpiresAt                   DateTime?
  passwordHash                        String?
  pcExpiryDate                        DateTime?
  phone                               String?
  smsNotifications                    Boolean                       @default(false)
  status                              UserStatus                    @default(ACTIVE)
  systemRole                          SystemRole                    @default(NONE)
  tenantId                            String?
  tenantRole                          TenantRole                    @default(ADVOCATE)
  theme                               String                        @default("light")
  updatedAt                           DateTime                      @default(now()) @updatedAt
  approvals                           Approval[]                    @relation("ApprovalUser")
  attendance                          Attendance[]
  auditLogs                           AuditLog[]                    @relation("AuditUser")
  createdEvents                       CalendarEvent[]               @relation("EventCreator")
  createdPaymentReceipts              PaymentReceipt[]              @relation("PaymentReceiptCreatedBy")
  createdCreditNotes                  CreditNote[]                  @relation("CreditNoteCreatedBy")
  createdComplianceReports            ComplianceReport[]            @relation("ComplianceReportCreatedBy")
  commissions                         CommissionPayout[]
  approvedCommissions                 CommissionPayout[]            @relation("CommissionApprovedBy")
  consentRecords                      ConsentRecord[]               @relation("ConsentUser")
  devices                             Device[]
  uploadedDocuments                   Document[]                    @relation("UploadedBy")
  employeeDocuments                   EmployeeDocument[]
  goals                               EmployeeGoal[]
  performance                         EmployeePerformance[]
  managedEmployees                    EmployeeProfile[]             @relation("EmployeeReportingManager")
  expenseEntries                      ExpenseEntry[]
  leaveRequests                       LeaveRequest[]
  approvedLeaves                      LeaveRequest[]                @relation("LeaveApprovedBy")
  matters                             Matter[]                      @relation("LeadAdvocate")
  originatorMatters                   MatterOriginator[]            @relation("OriginatorUser")
  taskAssignments                     MatterTask[]                  @relation("AssignedTo")
  mfaSecret                           MfaSecret?
  notifications                       Notification[]
  ownershipRecords                    OwnershipRecord[]             @relation("OwnerUser")
  cancelledInvoices                   Invoice[]                     @relation("InvoiceCancelledBy")
  payrollRecords                      PayrollRecord[]
  postedJournalEntries                JournalEntry[]                @relation("JournalPostedBy")
  closedAccountingPeriods             AccountingPeriod[]            @relation("PeriodClosedBy")
  importedBankStatements              BankStatement[]               @relation("BankStatementImportedBy")
  rateLimitLogs                       RateLimitLog[]
  receptionLogsReceived               ReceptionLog[]                @relation("ReceptionReceivedBy")
  sessions                            Session[]
  timeEntries                         TimeEntry[]
  branch                              Branch?                       @relation(fields: [branchId], references: [id])
  tenant                              Tenant?                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendedEvents                      CalendarEvent[]               @relation("EventAttendees")
  permissions                         Permission[]                  @relation("UserPermissions")
  roles                               Role[]                        @relation("UserRoles")
  generatedPayrollBatches             PayrollBatch[]                @relation("PayrollBatchGeneratedBy")
  approvedPayrollBatches              PayrollBatch[]                @relation("PayrollBatchApprovedBy")
  verifiedEmployeeDocuments           EmployeeDocument[]            @relation("EmployeeDocumentVerifiedBy")
  reviewedEmployeePerformances        EmployeePerformance[]         @relation("EmployeePerformanceReviewedBy")
  payslips                            Payslip[]
  timerSessions                       TimerSession[]
  clientKycVerified                   ClientKycProfile[]
  createdContracts                    Contract[]
  contractVersionsCreated             ContractVersion[]
  createdTasks                        MatterTask[]                  @relation("TaskCreator")
  taskComments                        TaskComment[]
  portalClients                       Client[]                      @relation("ClientPortalUser")
  clientComplianceChecksCreated       ClientComplianceCheck[]       @relation("ClientComplianceCheckCreatedBy")
  calendarRemindersCreated            CalendarReminder[]            @relation("CalendarReminderCreatedBy")
  calendarRemindersReceived           CalendarReminder[]            @relation("CalendarReminderRecipient")
  calendarSubscriptions               CalendarSubscription[]        @relation("CalendarSubscriptionOwner")
  externalCalendarAccounts            ExternalCalendarAccount[]     @relation("ExternalCalendarAccountOwner")
  rateCardsCreated                    RateCard[]                    @relation("RateCardCreatedBy")
  writeOffsCreated                    WriteOff[]                    @relation("WriteOffCreatedBy")
  writeOffsApproved                   WriteOff[]                    @relation("WriteOffApprovedBy")
  courtHearingsCreated                CourtHearing[]                @relation("CourtHearingCreatedBy")
  profitabilitySnapshotsCreated       MatterProfitabilitySnapshot[] @relation("ProfitabilitySnapshotCreatedBy")
  tenantMemberships                   TenantMembership[]
  disbursementRequestNotes            DisbursementRequestNote[]
  receivedWithholdingTaxCertificates  WithholdingTaxCertificate[]   @relation("WhtCertificateReceivedBy")
  cancelledWithholdingTaxCertificates WithholdingTaxCertificate[]   @relation("WhtCertificateCancelledBy")
  requestedPaymentRefunds             PaymentRefund[]               @relation("PaymentRefundRequestedBy")
  approvedPaymentRefunds              PaymentRefund[]               @relation("PaymentRefundApprovedBy")
  rejectedPaymentRefunds              PaymentRefund[]               @relation("PaymentRefundRejectedBy")
  paidPaymentRefunds                  PaymentRefund[]               @relation("PaymentRefundPaidBy")

  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@index([branchId])
  @@index([lastActivityAt])
}

model Role {
  id                String             @id @default(cuid())
  tenantId          String?
  name              String
  description       String?
  isSystem          Boolean            @default(false)
  parentRoleId      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  parentRole        Role?              @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles        Role[]             @relation("RoleHierarchy")
  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions       Permission[]       @relation("RolePermissions")
  users             User[]             @relation("UserRoles")
  tenantMemberships TenantMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id               String          @id @default(cuid())
  tenantId         String?
  action           String
  resource         String
  scope            PermissionScope
  description      String?
  conditions       String[]        @default([])
  constraints      Json            @default("{}")
  delegatedFrom    String?
  delegatedTo      String?
  delegationExpiry DateTime?
  isSystem         Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @default(now()) @updatedAt
  tenant           Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles            Role[]          @relation("RolePermissions")
  users            User[]          @relation("UserPermissions")

  @@unique([tenantId, action, resource], name: "unique_tenant_action_resource")
  @@index([tenantId])
  @@index([resource])
}

model PermissionCondition {
  id             String   @id @default(cuid())
  permissionId   String
  conditionType  String
  conditionValue String?
  operator       String
  createdAt      DateTime @default(now())

  @@index([permissionId])
}

model FieldAccessPolicy {
  id          String   @id @default(cuid())
  tenantId    String
  roleName    String
  entityType  String
  fieldName   String
  accessLevel String
  visibleTo   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([tenantId, roleName, entityType, fieldName])
  @@index([tenantId])
}

model OwnershipRecord {
  id           String   @id @default(cuid())
  resourceType String
  resourceId   String
  ownerId      String
  createdAt    DateTime @default(now())
  owner        User     @relation("OwnerUser", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([resourceType, resourceId])
  @@index([ownerId])
}

model ApiKey {
  id             String    @id @default(cuid())
  tenantId       String
  name           String
  description    String?
  keyHash        String    @unique
  prefix         String    @unique
  scopes         String[]  @default([])
  rateLimit      Int       @default(1000)
  ipWhitelist    String[]  @default([])
  allowedOrigins String[]  @default([])
  isActive       Boolean   @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?
  updatedAt      DateTime  @default(now()) @updatedAt
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isActive, expiresAt])
}

model Webhook {
  id             String    @id @default(cuid())
  tenantId       String
  name           String
  url            String
  events         String[]  @default([])
  secret         String
  isActive       Boolean   @default(true)
  lastDeliveryAt DateTime?
  failureCount   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantEncryptionKey {
  id           String    @id @default(cuid())
  tenantId     String
  keyAlgorithm String
  keyVersion   Int       @default(1)
  isActive     Boolean   @default(true)
  isRotated    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  rotatedAt    DateTime?
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
}

model FieldEncryption {
  id              String             @id @default(cuid())
  tenantId        String
  modelName       String
  fieldName       String
  isEncrypted     Boolean            @default(false)
  encryptionKeyId String?
  classification  DataClassification
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @default(now()) @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, modelName, fieldName])
  @@index([tenantId])
}

model SensitiveField {
  id                 String             @id @default(cuid())
  tenantId           String
  entityType         String
  fieldName          String
  classification     DataClassification
  requiresEncryption Boolean            @default(true)
  requiresMasking    Boolean            @default(false)
  maskingPattern     String?

  @@unique([tenantId, entityType, fieldName])
}

model ConsentRecord {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  consentType String
  version     String
  isGranted   Boolean   @default(false)
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User      @relation("ConsentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

model RateLimitLog {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String?
  apiKeyId      String?
  ipAddress     String
  endpoint      String
  method        String
  requestCount  Int      @default(1)
  windowStart   DateTime
  windowEnd     DateTime
  limitExceeded Boolean  @default(false)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, ipAddress, endpoint])
  @@index([limitExceeded])
}

model GlobalAuditLog {
  id             String   @id @default(cuid())
  actorId        String
  actorRole      String
  targetTenantId String?
  actionType     String
  severity       String   @default("INFO") // INFO, WARN, CRITICAL
  beforeState    Json?
  afterState     Json?
  hash           String // The cryptographic link to the previous entry
  requestId      String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([actorId])
  @@index([targetTenantId])
}

model AuditLog {
  id            String        @id @default(cuid())
  tenantId      String
  userId        String?
  deviceId      String?
  action        AuditAction
  severity      AuditSeverity @default(INFO)
  entityType    String
  entityId      String
  beforeData    Json?
  afterData     Json?
  changedFields String[]      @default([])
  ipAddress     String?
  userAgent     String?
  location      String?
  hash          String        @unique
  previousHash  String?
  success       Boolean       @default(true)
  failureReason String?
  correlationId String?
  reason        String?
  createdAt     DateTime      @default(now())
  device        Device?       @relation(fields: [deviceId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user          User?         @relation("AuditUser", fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action, severity])
  @@index([createdAt])
}

model AuditAlert {
  id              String         @id @default(cuid())
  tenantId        String
  triggerRule     String
  isActive        Boolean        @default(true)
  webhookUrl      String?
  emailRecipients String[]
  alertFrequency  AlertFrequency
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @default(now()) @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AuditLogArchive {
  id                  String   @id @default(cuid())
  tenantId            String
  originalAuditLogIds String[]
  archivedAt          DateTime
  archiveLocation     String
  archiveChecksum     String

  @@index([tenantId, archivedAt])
}

model DataLineage {
  id                 String   @id @default(cuid())
  tenantId           String
  sourceEntity       String
  sourceId           String
  targetEntity       String
