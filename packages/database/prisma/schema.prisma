generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                  String                @id @default(cuid())
  name                String                @unique
  slug                String                @unique
  description         String?
  kraPin              String                @unique
  etimsId             String?               @unique
  subscriptionPlan    String                @default("BASIC")
  subscriptionStatus  String                @default("ACTIVE")
  billingCycleStart   DateTime
  billingCycleEnd     DateTime
  logoUrl             String?
  faviconUrl          String?
  primaryColor        String                @default("#1A1A1A")
  accentColor         String                @default("#D4AF37")
  fontFamily          String                @default("Inter")
  currency            String                @default("KES")
  timezone            String                @default("Africa/Nairobi")
  locale              String                @default("en-KE")
  dateFormat          String                @default("DD/MM/YYYY")
  dataResidencyRegion String                @default("KE")
  complianceMode      Boolean               @default(true)
  enableEtims         Boolean               @default(true)
  enableTrust         Boolean               @default(true)
  enableAml           Boolean               @default(true)
  gdprMode            Boolean               @default(false)
  auditLogRetention   Int                   @default(2555)
  backupRetention     Int                   @default(90)
  betaFeatures        String[]              @default([])
  disabledFeatures    String[]              @default([])
  accountingMethod    String                @default("ACCRUAL")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  deletedAt           DateTime?
  lastLoginAt         DateTime?
  mPesaVolumeMonth    Decimal               @default(0) @db.Decimal(18, 2)
  storageUsedGb       Decimal               @default(0) @db.Decimal(10, 2)
  totalMatters        Int                   @default(0)
  totalUsers          Int                   @default(0)
  accountBalances     AccountBalance[]
  apiKeys             ApiKey[]
  approvals           Approval[]
  auditAlerts         AuditAlert[]
  auditLogs           AuditLog[]
  billingRuns         BillingRun[]
  branches            Branch[]
  chartOfAccounts     ChartOfAccount[]
  clients             Client[]
  consentRecords      ConsentRecord[]
  disputes            Dispute[]
  documents           Document[]
  evidenceItems       EvidenceItem[]
  expressServices     ExpressService[]
  featureFlags        FeatureFlag[]
  fieldEncryptions    FieldEncryption[]
  invoices            Invoice[]
  journalEntries      JournalEntry[]
  matterTemplates     MatterTemplate[]
  notifications       Notification[]
  officeAccounts      OfficeAccount[]
  payrollRecords      PayrollRecord[]
  permissions         Permission[]
  rateLimitLogs       RateLimitLog[]
  receptionLogs       ReceptionLog[]
  roles               Role[]
  saasActivityLogs    SaasActivityLog[]
  suppliers           Supplier[]
  encryptionKeys      TenantEncryptionKey[]
  trustAccounts       TrustAccount[]
  users               User[]
  webhooks            Webhook[]
  workflows           Workflow[]
  workspaces          Workspace[]

  @@index([subscriptionStatus])
  @@index([createdAt])
  @@index([dataResidencyRegion])
}

model Workspace {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  brand       String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Branch {
  id             String          @id @default(cuid())
  tenantId       String
  name           String
  kraPin         String          @unique
  etimsId        String?         @unique
  location       String?
  phone          String?
  email          String?
  etimsDrn       String?         @unique
  vscuSerial     String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  matters        Matter[]
  officeAccounts OfficeAccount[]
  trustAccounts  TrustAccount[]
  users          User[]

  @@unique([tenantId, kraPin])
  @@index([tenantId])
}

model Device {
  id                 String            @id @default(cuid())
  userId             String
  deviceFingerprint  String            @unique
  deviceName         String
  deviceType         String
  osName             String?
  osVersion          String?
  browserName        String?
  browserVersion     String?
  trustStatus        DeviceTrustStatus @default(UNTRUSTED)
  trustedAt          DateTime?
  trustedBy          String?
  lastUsedAt         DateTime          @default(now())
  ipAddressHistory   String[]          @default([])
  locationHistory    String[]          @default([])
  lastIpAddress      String?
  lastLocation       String?
  riskScore          Int               @default(0)
  suspiciousActivity Boolean           @default(false)
  flags              String[]          @default([])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt
  auditLogs          AuditLog[]
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions           Session[]

  @@index([userId])
  @@index([trustStatus])
  @@index([lastUsedAt])
}

model Session {
  id                  String        @id @default(cuid())
  userId              String
  deviceId            String?
  tenantId            String?
  sessionToken        String        @unique
  refreshToken        String?       @unique
  tokenVersion        Int           @default(1)
  status              SessionStatus @default(ACTIVE)
  issuedAt            DateTime      @default(now())
  expiresAt           DateTime
  lastActivityAt      DateTime      @default(now())
  lastActivityType    String?
  ipAddress           String
  userAgent           String
  location            String?
  mfaVerified         Boolean       @default(false)
  mfaMethod           MfaMethod?
  mfaVerifiedAt       DateTime?
  riskLevel           String        @default("LOW")
  requiresMfaReverify Boolean       @default(false)
  suspiciousActivity  Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @default(now()) @updatedAt
  device              Device?       @relation(fields: [deviceId], references: [id])
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, expiresAt])
  @@index([deviceId])
  @@index([lastActivityAt])
}

model MfaSecret {
  id              String    @id @default(cuid())
  userId          String    @unique
  totpSecret      String?
  totpVerified    Boolean   @default(false)
  backupCodes     String?
  backupCodesUsed String[]  @default([])
  otpToken        String?
  otpExpiresAt    DateTime?
  otpAttempts     Int       @default(0)
  otpMaxAttempts  Int       @default(3)
  recoveryEmail   String?
  recoveryPhone   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  name                  String
  accountNumber         String?
  admissionNumber       String?               @unique
  bankName              String?
  basicSalary           Decimal               @default(0) @db.Decimal(12, 2)
  branchId              String?
  createdAt             DateTime              @default(now())
  defaultRate           Decimal               @default(0) @db.Decimal(12, 2)
  deletedAt             DateTime?
  department            String?
  emailNotifications    Boolean               @default(true)
  failedLoginAttempts   Int                   @default(0)
  googleId              String?               @unique
  idNumber              String?               @unique
  isLocked              Boolean               @default(false)
  kraPin                String?
  language              String                @default("en-KE")
  lastActivityAt        DateTime              @default(now())
  lastLoginAt           DateTime?
  lockReason            String?
  lockedUntil           DateTime?
  nhifNumber            String?
  nssfNumber            String?
  oauth2Providers       String[]              @default([])
  passwordChangedAt     DateTime?
  passwordExpiresAt     DateTime?
  passwordHash          String?
  pcExpiryDate          DateTime?
  phone                 String?
  smsNotifications      Boolean               @default(false)
  status                String                @default("ACTIVE")
  systemRole            SystemRole            @default(NONE)
  tenantId              String?
  tenantRole            TenantRole            @default(ADVOCATE)
  theme                 String                @default("light")
  updatedAt             DateTime              @default(now()) @updatedAt
  approvals             Approval[]            @relation("ApprovalUser")
  attendance            Attendance[]
  auditLogs             AuditLog[]            @relation("AuditUser")
  createdEvents         CalendarEvent[]       @relation("EventCreator")
  commissions           CommissionPayout[]
  consentRecords        ConsentRecord[]       @relation("ConsentUser")
  devices               Device[]
  uploadedDocuments     Document[]            @relation("UploadedBy")
  employeeDocuments     EmployeeDocument[]
  goals                 EmployeeGoal[]
  performance           EmployeePerformance[]
  expenseEntries        ExpenseEntry[]
  leaveRequests         LeaveRequest[]
  matters               Matter[]              @relation("LeadAdvocate")
  originatorMatters     MatterOriginator[]    @relation("OriginatorUser")
  taskAssignments       MatterTask[]          @relation("AssignedTo")
  mfaSecret             MfaSecret?
  notifications         Notification[]
  ownershipRecords      OwnershipRecord[]     @relation("OwnerUser")
  payrollRecords        PayrollRecord[]
  rateLimitLogs         RateLimitLog[]
  receptionLogsReceived ReceptionLog[]        @relation("ReceptionReceivedBy")
  sessions              Session[]
  timeEntries           TimeEntry[]
  branch                Branch?               @relation(fields: [branchId], references: [id])
  tenant                Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendedEvents        CalendarEvent[]       @relation("EventAttendees")
  permissions           Permission[]          @relation("UserPermissions")
  roles                 Role[]                @relation("UserRoles")

  @@unique([tenantId, email], name: "unique_tenant_email")
  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@index([branchId])
  @@index([lastActivityAt])
}

model Role {
  id           String       @id @default(cuid())
  tenantId     String?
  name         String
  description  String?
  isSystem     Boolean      @default(false)
  parentRoleId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @default(now()) @updatedAt
  parentRole   Role?        @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  childRoles   Role[]       @relation("RoleHierarchy")
  tenant       Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions  Permission[] @relation("RolePermissions")
  users        User[]       @relation("UserRoles")

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id               String          @id @default(cuid())
  tenantId         String?
  action           String
  resource         String
  scope            PermissionScope
  description      String?
  conditions       String[]        @default([])
  constraints      Json            @default("{}")
  delegatedFrom    String?
  delegatedTo      String?
  delegationExpiry DateTime?
  isSystem         Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @default(now()) @updatedAt
  tenant           Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles            Role[]          @relation("RolePermissions")
  users            User[]          @relation("UserPermissions")

  @@unique([tenantId, action, resource], name: "unique_tenant_action_resource")
  @@index([tenantId])
  @@index([resource])
}

model PermissionCondition {
  id             String   @id @default(cuid())
  permissionId   String
  conditionType  String
  conditionValue String?
  operator       String
  createdAt      DateTime @default(now())

  @@index([permissionId])
}

model FieldAccessPolicy {
  id          String   @id @default(cuid())
  tenantId    String
  roleName    String
  entityType  String
  fieldName   String
  accessLevel String
  visibleTo   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([tenantId, roleName, entityType, fieldName])
  @@index([tenantId])
}

model OwnershipRecord {
  id           String   @id @default(cuid())
  resourceType String
  resourceId   String
  ownerId      String
  createdAt    DateTime @default(now())
  owner        User     @relation("OwnerUser", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([resourceType, resourceId])
  @@index([ownerId])
}

model ApiKey {
  id             String    @id @default(cuid())
  tenantId       String
  name           String
  description    String?
  keyHash        String    @unique
  prefix         String    @unique
  scopes         String[]  @default([])
  rateLimit      Int       @default(1000)
  ipWhitelist    String[]  @default([])
  allowedOrigins String[]  @default([])
  isActive       Boolean   @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?
  updatedAt      DateTime  @default(now()) @updatedAt
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isActive, expiresAt])
}

model Webhook {
  id             String    @id @default(cuid())
  tenantId       String
  name           String
  url            String
  events         String[]  @default([])
  secret         String
  isActive       Boolean   @default(true)
  lastDeliveryAt DateTime?
  failureCount   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantEncryptionKey {
  id           String    @id @default(cuid())
  tenantId     String
  keyAlgorithm String
  keyVersion   Int       @default(1)
  isActive     Boolean   @default(true)
  isRotated    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  rotatedAt    DateTime?
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
}

model FieldEncryption {
  id              String             @id @default(cuid())
  tenantId        String
  modelName       String
  fieldName       String
  isEncrypted     Boolean            @default(false)
  encryptionKeyId String?
  classification  DataClassification
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @default(now()) @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, modelName, fieldName])
  @@index([tenantId])
}

model SensitiveField {
  id                 String             @id @default(cuid())
  tenantId           String
  entityType         String
  fieldName          String
  classification     DataClassification
  requiresEncryption Boolean            @default(true)
  requiresMasking    Boolean            @default(false)
  maskingPattern     String?

  @@unique([tenantId, entityType, fieldName])
}

model ConsentRecord {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  consentType String
  version     String
  isGranted   Boolean   @default(false)
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User      @relation("ConsentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

model RateLimitLog {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String?
  apiKeyId      String?
  ipAddress     String
  endpoint      String
  method        String
  requestCount  Int      @default(1)
  windowStart   DateTime
  windowEnd     DateTime
  limitExceeded Boolean  @default(false)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, ipAddress, endpoint])
  @@index([limitExceeded])
}

model AuditLog {
  id            String        @id @default(cuid())
  tenantId      String
  userId        String?
  deviceId      String?
  action        AuditAction
  severity      AuditSeverity @default(INFO)
  entityType    String
  entityId      String
  beforeData    Json?
  afterData     Json?
  changedFields String[]      @default([])
  ipAddress     String?
  userAgent     String?
  location      String?
  hash          String        @unique
  previousHash  String?
  success       Boolean       @default(true)
  failureReason String?
  correlationId String?
  reason        String?
  createdAt     DateTime      @default(now())
  device        Device?       @relation(fields: [deviceId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?         @relation("AuditUser", fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action, severity])
  @@index([createdAt])
}

model AuditAlert {
  id              String   @id @default(cuid())
  tenantId        String
  triggerRule     String
  isActive        Boolean  @default(true)
  webhookUrl      String?
  emailRecipients String[]
  alertFrequency  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AuditLogArchive {
  id                  String   @id @default(cuid())
  tenantId            String
  originalAuditLogIds String[]
  archivedAt          DateTime
  archiveLocation     String
  archiveChecksum     String

  @@index([tenantId, archivedAt])
}

model DataLineage {
  id                 String   @id @default(cuid())
  tenantId           String
  sourceEntity       String
  sourceId           String
  targetEntity       String
  targetId           String
  transformationType String
  createdAt          DateTime @default(now())

  @@index([sourceEntity, sourceId])
  @@index([targetEntity, targetId])
}

model FeatureFlag {
  id                String    @id @default(cuid())
  tenantId          String
  name              String
  description       String?
  isEnabled         Boolean   @default(false)
  rolloutPercentage Int       @default(0)
  targetUsers       String[]  @default([])
  targetRoles       String[]  @default([])
  targetBranches    String[]  @default([])
  launchDate        DateTime?
  sunsetDate        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([isEnabled])
}

model DatabaseCache {
  id        String   @id @default(cuid())
  tenantId  String?
  cacheKey  String   @unique
  cacheData Json
  version   Int      @default(1)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([tenantId])
  @@index([expiresAt])
}

model Workflow {
  id                String            @id @default(cuid())
  tenantId          String
  name              String
  description       String?
  type              String
  states            String[]
  startState        String
  endStates         String[]
  isActive          Boolean           @default(true)
  triggerConditions Json              @default("{}")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @default(now()) @updatedAt
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  history           WorkflowHistory[]

  @@index([tenantId])
}

model WorkflowHistory {
  id               String   @id @default(cuid())
  workflowId       String
  entityType       String
  entityId         String
  fromState        String
  toState          String
  transitionReason String?
  transitionBy     String
  transitionAt     DateTime @default(now())
  workflow         Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, transitionAt])
  @@index([entityType, entityId])
}

model Approval {
  id               String         @id @default(cuid())
  tenantId         String
  entityType       String
  entityId         String
  currentState     WorkflowState
  nextState        WorkflowState
  approvedBy       String?
  status           ApprovalStatus @default(PENDING)
  comment          String?
  rejectionReason  String?
  createdAt        DateTime       @default(now())
  approvedAt       DateTime?
  deadlineAt       DateTime?
  escalatedAt      DateTime?
  escalatedTo      String?
  escalationReason String?
  delegatedFrom    String?
  delegatedTo      String?
  approver         User?          @relation("ApprovalUser", fields: [approvedBy], references: [id])
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([deadlineAt])
}

model Dispute {
  id                 String        @id @default(cuid())
  tenantId           String
  entityType         String
  entityId           String
  raisedBy           String
  raisedAt           DateTime      @default(now())
  description        String
  evidenceUrl        String?
  status             DisputeStatus @default(PENDING_REVIEW)
  investigatedBy     String?
  investigationNotes String?
  resolvedAt         DateTime?
  resolution         String?
  resolutionNotes    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @default(now()) @updatedAt
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([entityType, entityId])
}

model EvidenceItem {
  id                   String       @id @default(cuid())
  tenantId             String
  matterId             String
  type                 EvidenceType
  title                String
  description          String?
  fileUrl              String
  fileHash             String
  submittedBy          String
  submittedAt          DateTime     @default(now())
  accessLog            Json[]       @default([])
  isSensitive          Boolean      @default(false)
  confidentialityLevel String       @default("PUBLIC")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @default(now()) @updatedAt
  matter               Matter       @relation(fields: [matterId], references: [id], onDelete: Cascade)
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([matterId])
  @@index([confidentialityLevel])
}

model Contract {
  id                 String            @id @default(cuid())
  matterId           String
  title              String
  currentStatus      ContractStatus    @default(DRAFTING)
  activeVersionId    String?
  isExternalViewable Boolean           @default(false)
  externalAccessKey  String?           @unique
  createdAt          DateTime          @default(now())
  matter             Matter            @relation(fields: [matterId], references: [id])
  versions           ContractVersion[]
}

model ContractVersion {
  id             String   @id @default(cuid())
  contractId     String
  versionNumber  Int
  fileUrl        String
  changesSummary String?
  createdAt      DateTime @default(now())
  contract       Contract @relation(fields: [contractId], references: [id])
}

model ExpressService {
  id          String   @id @default(cuid())
  tenantId    String
  clientName  String
  serviceType String
  amount      Decimal  @db.Decimal(14, 2)
  isPaid      Boolean  @default(false)
  mpesaRef    String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Matter {
  id                       String                @id @default(cuid())
  branchId                 String
  title                    String
  caseNumber               String                @unique
  status                   MatterStatus          @default(ACTIVE)
  category                 String
  description              String?
  trustBalance             Decimal               @default(0) @db.Decimal(12, 2)
  wipValue                 Decimal               @default(0) @db.Decimal(12, 2)
  riskLevel                String                @default("LOW")
  clientId                 String
  leadAdvocateId           String
  openedDate               DateTime              @default(now())
  closedDate               DateTime?
  archivedDate             DateTime?
  statuteOfLimitationsDate DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @default(now()) @updatedAt
  deletedAt                DateTime?
  calendarEvents           CalendarEvent[]
  clientTrustLedgers       ClientTrustLedger[]   @relation("MatterTrustTransactions")
  contracts                Contract[]
  disbursements            Disbursement[]
  documents                Document[]
  evidenceItems            EvidenceItem[]
  expenseEntries           ExpenseEntry[]
  invoices                 Invoice[]
  journalEntries           JournalEntry[]
  branch                   Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  client                   Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadAdvocate             User                  @relation("LeadAdvocate", fields: [leadAdvocateId], references: [id])
  liens                    MatterLien[]
  originator               MatterOriginator?
  parties                  MatterParty[]
  tasks                    MatterTask[]
  receptionLogs            ReceptionLog[]
  statute                  StatuteOfLimitations?
  timeEntries              TimeEntry[]
  trustTransactions        TrustTransaction[]
  unbilledWip              UnbilledWip?

  @@index([branchId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model MatterOriginator {
  id             String   @id @default(cuid())
  matterId       String   @unique
  originatorId   String
  commissionRate Decimal  @db.Decimal(5, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
