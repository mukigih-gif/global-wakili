  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  kraPin     String
  etimsId    String?
  email      String?
  phone      String?
  expenses   ExpenseEntry[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@unique([tenantId, kraPin])
  @@index([tenantId])
}

