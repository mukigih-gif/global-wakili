# ── Global Wakili marketing site — environment variables ──────────────────────
# Set these in Vercel → Project → Settings → Environment Variables.
# NOTE: NEXT_PUBLIC_* vars are inlined at BUILD time — after adding/changing a
# value in Vercel you must trigger a redeploy for it to take effect.

# Web3Forms demo-form delivery (public access key — safe client-side; only allows
# submitting to the email tied to the key). Leads are delivered to that inbox.
# Get yours: https://web3forms.com  → enter wakili@globalsitesltd.com → copy Access Key
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# analytics.google.com → Admin → Data Streams → Web → copy Measurement ID
NEXT_PUBLIC_GA_ID=

# Google Tag Manager container ID (format: GTM-XXXXXXX)
# tagmanager.google.com → create/open container → copy ID
NEXT_PUBLIC_GTM_ID=
