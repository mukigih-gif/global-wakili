{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "description": "Global Wakili API service",
  "main": "src/server.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node --require tsx/cjs src/server.ts",
    "start:compiled": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "build": "prisma generate --schema=../../packages/database/prisma/schema.prisma && tsc",
    "test": "node --require tsx/cjs --test src/**/__tests__/*.test.ts",
    "test:tenant": "node --require tsx/cjs --test src/__tests__/tenant-isolation.test.ts",
    "test:integration": "node --require tsx/cjs --test src/__tests__/integration/*.integration.test.ts",
    "test:all": "node --require tsx/cjs --test src/**/__tests__/**/*.test.ts src/__tests__/integration/*.integration.test.ts",
    "test:api": "jest --config jest.config.js --runInBand",
    "provision:tenant": "node --require tsx/cjs src/scripts/provision-tenant.ts",
    "provision:all": "node --require tsx/cjs src/scripts/reprovision-all-tenants.ts",
    "seed:permissions": "node --require tsx/cjs src/scripts/seed-permissions.ts",
    "worker:notifications": "node --require tsx/cjs src/modules/notifications/workers/notification.worker.ts",
    "worker:retention": "node --require tsx/cjs src/modules/document/DocumentRetentionRunner.ts",
    "worker:passive-capture": "node --require tsx/cjs src/modules/matter/workers/passive-capture.worker.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@aws-sdk/client-s3": "^3.1059.0",
    "@aws-sdk/s3-request-presigner": "^3.1059.0",
    "@global-wakili/database": "file:../../packages/database",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "africastalking": "^0.7.9",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.75.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-loki": "^3.0.0",
    "rate-limit-redis": "^5.0.0",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
