{
  "installCommand": "npm install --prefix apps/web",
  "buildCommand": "cd apps/web && next build",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://global-wakili-api.onrender.com/:path*"
    }
  ]
}
