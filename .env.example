# =============================================================================
# Global Wakili Legal Enterprise — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real credentials.
# All variables marked [required] must be set before the application will start.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development                          # development | test | production [required]
PORT=5000                                     # API server port
LOG_LEVEL=info                                # debug | info | warn | error

# -----------------------------------------------------------------------------
# Database (PostgreSQL / Neon)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/global_wakili?sslmode=verify-full   # [required]
DIRECT_URL=postgresql://user:password@localhost:5432/global_wakili?sslmode=verify-full     # Prisma direct connection (bypasses pgBouncer)
USE_NEON=false                                # Set true when using Neon serverless driver

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
JWT_SECRET=your-256-bit-secret-here-min-32-chars-change-in-production   # [required] min 32 chars
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here-change-in-production
JWT_EXPIRES_IN=15m
ENCRYPTION_KEY=                               # 64 hex chars (32 bytes) — required in production

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
APP_URL=http://localhost:5000
APP_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Redis (optional in development, required in production)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ENABLED=false
REDIS_QUEUE_ENABLED=false

# -----------------------------------------------------------------------------
# KRA eTIMS (VAT compliance)
# -----------------------------------------------------------------------------
ETIMS_BASE_URL=https://etims-sbx.kra.go.ke/etims-api   # Sandbox URL
ETIMS_API_KEY=dev_key_change_in_production
KRA_ETIMS_URL=https://etims-sbx.kra.go.ke/etims-api
KRA_ETIMS_TOKEN=dev_token_change_in_production
DEFAULT_WHT_RATE=5                            # Default withholding tax rate (%)

# -----------------------------------------------------------------------------
# GOAML (Anti-Money Laundering reporting)
# -----------------------------------------------------------------------------
GOAML_BASE_URL=https://goaml.example.ke/api
GOAML_API_KEY=dev_key_change_in_production
GOAML_USERNAME=dev_username_change_in_production

# -----------------------------------------------------------------------------
# M-Pesa (Safaricom Daraja API)
# -----------------------------------------------------------------------------
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=dev_key_change_in_production
MPESA_CONSUMER_SECRET=dev_key_change_in_production
MPESA_SHORTCODE=174379
MPESA_PASSKEY=dev_passkey_change_in_production
MPESA_BUSINESS_CODE=dev_key_change_in_production
MPESA_INITIATOR_NAME=dev_key_change_in_production
MPESA_INITIATOR_PASSWORD=dev_key_change_in_production

# -----------------------------------------------------------------------------
# Email — SMTP (production primary)
# -----------------------------------------------------------------------------
# Set SMTP_HOST to enable real email delivery via Nodemailer.
# If only SENDGRID_API_KEY is set (no SMTP_HOST), SendGrid SMTP relay is used.
# If neither is set, email is simulated (logged to console only).
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=dev_key_change_in_production
SMTP_PASS=dev_key_change_in_production
SMTP_SECURE=false
SMTP_FROM_EMAIL=noreply@globalwakili.co.ke
NOTIFICATION_FROM_EMAIL=noreply@globalwakili.co.ke

# Email — SendGrid (alternative to SMTP)
SENDGRID_API_KEY=dev_key_change_in_production
SENDGRID_FROM_EMAIL=noreply@globalwakili.co.ke

# -----------------------------------------------------------------------------
# SMS — Africa's Talking (Kenya primary provider)
# -----------------------------------------------------------------------------
# Set AT_API_KEY + AT_USERNAME to enable real SMS via Africa's Talking.
# Register at: https://africastalking.com
AT_API_KEY=dev_key_change_in_production
AT_USERNAME=sandbox
SMS_SENDER_ID=GlobalWakili
NOTIFICATION_SMS_SENDER_ID=GlobalWakili

# SMS — Twilio (fallback if AT not configured)
# Register at: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=dev_key_change_in_production
TWILIO_AUTH_TOKEN=dev_key_change_in_production
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Push Notifications — Firebase Cloud Messaging (FCM)
# -----------------------------------------------------------------------------
# Set all three to enable real push notifications via FCM.
# Create a service account at: https://console.firebase.google.com
FCM_PROJECT_ID=dev_key_change_in_production
FCM_CLIENT_EMAIL=dev_key_change_in_production
FCM_PRIVATE_KEY=dev_key_change_in_production

# -----------------------------------------------------------------------------
# Notification Engine Settings
# -----------------------------------------------------------------------------
NOTIFICATION_DIGEST_HOUR=8         # Hour (0-23) to send daily/weekly digests

# -----------------------------------------------------------------------------
# Document Storage
# -----------------------------------------------------------------------------
DOCUMENT_STORAGE_PROVIDER=local             # local | s3 | gcs | azure

# Local storage
DOCUMENT_LOCAL_STORAGE_DIR=./storage/documents

# AWS S3
AWS_ACCESS_KEY_ID=dev_key_change_in_production
AWS_SECRET_ACCESS_KEY=dev_key_change_in_production
AWS_REGION=us-east-1
AWS_S3_BUCKET=global-wakili-documents
DOCUMENT_S3_BUCKET=global-wakili-documents

# Google Cloud Storage
DOCUMENT_GCS_BUCKET=global-wakili-documents

# Azure Blob Storage
DOCUMENT_AZURE_CONTAINER=global-wakili-documents

# Document options
DOCUMENT_SIGNING_SECRET=dev_signing_secret_change_in_production
DOCUMENT_MALWARE_SCANNER_PROVIDER=none      # none | clamav | external
DOCUMENT_MALWARE_SCAN_REQUIRED=false
DOCUMENT_PDF_RENDERER_ENABLED=false

# -----------------------------------------------------------------------------
# OAuth Providers
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=dev_key_change_in_production
GOOGLE_CLIENT_SECRET=dev_key_change_in_production
MICROSOFT_CLIENT_ID=dev_key_change_in_production
MICROSOFT_CLIENT_SECRET=dev_key_change_in_production
MS365_CLIENT_ID=dev_key_change_in_production
MS365_CLIENT_SECRET=dev_key_change_in_production

# -----------------------------------------------------------------------------
# Realtime (Pusher)
# -----------------------------------------------------------------------------
PUSHER_APP_ID=dev_key_change_in_production
PUSHER_KEY=dev_key_change_in_production
PUSHER_SECRET=dev_key_change_in_production
PUSHER_CLUSTER=mt1

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your_sentry_dsn_here
SLOW_QUERY_THRESHOLD_MS=1000

# -----------------------------------------------------------------------------
# Bootstrap Seed (development only)
# -----------------------------------------------------------------------------
SEED_TENANT_NAME="Global Wakili Legal Enterprise"
SEED_TENANT_SLUG="global-wakili-legal-enterprise"
SEED_TENANT_KRA_PIN="A123456789B"
SEED_PLATFORM_ADMIN_EMAIL="platform.admin@globalwakili.local"
SEED_PLATFORM_ADMIN_NAME="Platform Super Admin"
SEED_FIRM_ADMIN_EMAIL="firm.admin@globalwakili.local"
SEED_FIRM_ADMIN_NAME="Firm Administrator"
SEED_DEFAULT_PASSWORD_HASH=                  # bcrypt hash of the seed admin password
