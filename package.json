{
  "name": "global-wakili-root",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise Legal Matter Management Root",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "db:pull": "npx prisma db pull --schema=packages/database/prisma/schema.prisma --config=packages/database/prisma/prisma.config.ts",
    "db:push": "npx prisma db push --schema=packages/database/prisma/schema.prisma --config=packages/database/prisma/prisma.config.ts",
    "db:gen": "npx prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=packages/database/prisma/schema.prisma --config=packages/database/prisma/prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "fs-extra": "^11.3.4",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}