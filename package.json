{
  "name": "global-wakili-root",
  "version": "1.0.0",
  "private": true,
  "description": "Global Wakili Enterprise Legal Matter Management Root",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
  "dev:api": "npm run dev --workspace=apps/api",
  "dev:web": "npm run dev --workspace=apps/web",

  "db:format": "prisma format --config ./prisma.config.ts",
  "db:validate": "prisma validate --config ./prisma.config.ts",
  "db:gen": "prisma generate --config ./prisma.config.ts",
  "db:status": "prisma migrate status --config ./prisma.config.ts",
  "db:deploy": "prisma migrate deploy --config ./prisma.config.ts",
  "db:reset": "prisma migrate reset --config ./prisma.config.ts",
  "db:seed": "prisma db seed --config ./prisma.config.ts",

  "db:pull": "prisma db pull --config ./prisma.config.ts",
  "db:push": "prisma db push --config ./prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "fs-extra": "^11.3.4",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
